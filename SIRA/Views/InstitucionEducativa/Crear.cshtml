@model SIRA.ViewModels.InstitucionEducativaViewModel
@using SIRA.Models
@{
    ViewData["Title"] = "Nueva Institución Educativa";
    var admins = ViewBag.Administradores as IEnumerable<Administrador> ?? Enumerable.Empty<Administrador>();
}

<div class="page-crear">
    <div class="container" style="max-width:680px;">

        <!-- Cabecera -->
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <span class="d-inline-flex align-items-center justify-content-center rounded-circle"
                      style="width:52px;height:52px;background-color:var(--sira-accent);flex-shrink:0;">
                    <i class="bi bi-building-fill text-white fs-4"></i>
                </span>
                <div>
                    <h1 class="h4 fw-bold mb-0" style="color:var(--sira-navy);">Nueva Institución Educativa</h1>
                    <p class="text-muted mb-0 small">Complete los datos de la institución</p>
                </div>
            </div>
            <a asp-action="Index"
               class="btn btn-sm btn-outline-secondary fw-semibold">
                <i class="bi bi-arrow-left me-1"></i>Volver al listado
            </a>
        </div>

        <!-- Formulario -->
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                <form asp-action="Crear" method="post" autocomplete="off">
                    @Html.AntiForgeryToken()

                    <!-- Nombre institución -->
                    <div class="mb-3">
                        <label asp-for="NombreInstitucion" class="form-label fw-semibold">
                            Nombre de la institución <span class="text-danger">*</span>
                        </label>
                        <input asp-for="NombreInstitucion" class="form-control"
                               placeholder="Ej. SENA CAE Curumaní" />
                        <span asp-validation-for="NombreInstitucion" class="text-danger small"></span>
                    </div>

                    <!-- Dirección -->
                    <div class="mb-3">
                        <label asp-for="Direccion" class="form-label fw-semibold">
                            Dirección <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Direccion" class="form-control"
                               placeholder="Ej. Calle 10 # 5-32, Curumaní, Cesar" />
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>

                    <!-- Teléfono -->
                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label fw-semibold">
                            Teléfono <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Telefono" class="form-control"
                               placeholder="Ej. 311 3207139" />
                        <span asp-validation-for="Telefono" class="text-danger small"></span>
                    </div>

                    <!-- Administrador asignado -->
                    <div class="mb-4">
                        <label asp-for="IdAdministrador" class="form-label fw-semibold">
                            Administrador asignado <span class="text-danger">*</span>
                        </label>
                        @if (!admins.Any())
                        {
                            <div class="alert alert-warning py-2">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                No hay administradores disponibles. Todos ya tienen una institución asignada.
                            </div>
                        }
                        else
                        {
                            <select asp-for="IdAdministrador" class="form-select">
                                <option value="0">— Seleccione un administrador —</option>
                                @foreach (var admin in admins)
                                {
                                    <option value="@admin.IdAdministrador">@admin.NombreCompleto</option>
                                }
                            </select>
                        }
                        <span asp-validation-for="IdAdministrador" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn fw-semibold py-2 flex-fill"
                                style="background-color:var(--sira-accent);color:#fff;border-color:var(--sira-accent);"
                                @(!admins.Any() ? "disabled" : "")>
                            <i class="bi bi-building-add me-2"></i>Guardar Institución
                        </button>
                        <a asp-action="Index"
                           class="btn btn-outline-secondary fw-semibold py-2">
                            Cancelar
                        </a>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
