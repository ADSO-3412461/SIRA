@{
    ViewData["Title"] = "Inicio";
}

<!-- =====================================================
     SECCIÓN HERO
     ===================================================== -->
<section class="hero-section">
    <div>
        <h1>
            Sistema Integral de<br />
            Registro de Ausencias
        </h1>
        <p class="lead">
            Gestiona las inasistencias de tu estudiante<br class="d-none d-md-inline" />
            de forma rápida y segura.
        </p>
        <a href="/Home/Instituciones" class="btn-cta">
            <i class="bi bi-file-earmark-plus me-2"></i>Registrar Excusa
        </a>
    </div>
</section>

<!-- =====================================================
     SECCIÓN ¿CÓMO FUNCIONA?
     ===================================================== -->
<section class="how-section" id="como-funciona">
    <div class="container">

        <div class="text-center">
            <h2 class="section-title">¿Cómo funciona?</h2>
            <p class="section-subtitle">Tres pasos simples para registrar una ausencia.</p>
        </div>

        <div class="row g-4 justify-content-center">

            <!-- Paso 1 -->
            <div class="col-12 col-md-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <div class="step-icon">
                        <i class="bi bi-ui-checks"></i>
                    </div>
                    <h5>Completa el formulario</h5>
                    <p>Ingresa los datos del estudiante, la fecha y el motivo de la ausencia.</p>
                </div>
            </div>

            <!-- Paso 2 -->
            <div class="col-12 col-md-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <div class="step-icon">
                        <i class="bi bi-paperclip"></i>
                    </div>
                    <h5>Adjunta el soporte</h5>
                    <p>Carga el documento o imagen justificante en formato JPG o PDF.</p>
                </div>
            </div>

            <!-- Paso 3 -->
            <div class="col-12 col-md-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <div class="step-icon">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <h5>El sistema notifica</h5>
                    <p>La institución recibe la notificación automáticamente para su revisión.</p>
                </div>
            </div>

        </div>
    </div>
</section>
