@model IEnumerable<SIRA.Models.InstitucionEducativa>
@{
    ViewData["Title"] = "Selecciona tu institución educativa";
    var lista = Model.ToList();
}

<style>
    .card-activa {
        border: 2px solid #1a2e4a !important;
        background-color: #ffffff;
        cursor: pointer;
        transition: transform .2s ease, box-shadow .2s ease;
    }
    .card-activa:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 24px rgba(0, 0, 0, .18) !important;
    }
    .card-inactiva {
        background-color: #f0f0f0 !important;
        border: 1px solid #cccccc !important;
        cursor: not-allowed;
    }
    .card-inactiva .titulo-inactivo,
    .card-inactiva .card-text,
    .card-inactiva .footer-inactivo {
        color: #999999 !important;
    }
</style>

<div class="container py-5">

    <!-- Cabecera -->
    <div class="text-center mb-5">
        <span class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 mt-5"
              style="width:64px;height:64px;background-color:#1a2e4a;">
            <i class="bi bi-building-fill text-white fs-2"></i>
        </span>
        <h2 class="fw-bold" style="color:#1a2e4a;">Selecciona tu institución educativa</h2>
        <p class="text-muted">Elige la institución a la que pertenece el estudiante para continuar.</p>
    </div>

    <!-- Alerta de error -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
            <span>@TempData["Error"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Alerta de advertencia (sin estudiantes) -->
    @if (TempData["Advertencia"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show d-flex align-items-center gap-2 mb-4" role="alert">
            <i class="bi bi-people-fill flex-shrink-0"></i>
            <span>@TempData["Advertencia"]</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Sin instituciones -->
    @if (!lista.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-building fs-1 d-block mb-3"></i>
            <p class="mb-0">No hay instituciones educativas registradas aún.<br />Contacte al administrador del sistema.</p>
        </div>
    }
    else
    {
        <!-- Grilla de tarjetas -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var inst in lista)
            {
                @if (inst.EsActivo)
                {
                    <!-- Tarjeta activa -->
                    <div class="col">
                        <a href="/Excusas/Crear?idInstitucion=@inst.IdInstitucionEducativa"
                           class="text-decoration-none">
                            <div class="card h-100 card-activa shadow-sm">
                                <div class="card-body d-flex flex-column gap-2 p-4">
                                    <div class="d-flex align-items-center gap-3 mb-1">
                                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                                              style="width:44px;height:44px;background-color:#1a2e4a;">
                                            <i class="bi bi-building-fill text-white"></i>
                                        </span>
                                        <h5 class="card-title fw-bold mb-0" style="color:#1a2e4a;">
                                            @inst.NombreInstitucion
                                        </h5>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(inst.Direccion))
                                    {
                                        <p class="card-text text-muted small mb-0">
                                            <i class="bi bi-geo-alt-fill me-1"></i>@inst.Direccion
                                        </p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(inst.Telefono))
                                    {
                                        <p class="card-text text-muted small mb-0">
                                            <i class="bi bi-telephone-fill me-1"></i>@inst.Telefono
                                        </p>
                                    }
                                </div>
                                <div class="card-footer border-0 py-2 px-4"
                                     style="background-color:#1a2e4a;">
                                    <span class="text-white small fw-semibold">
                                        <i class="bi bi-arrow-right-circle me-1"></i>Seleccionar institución
                                    </span>
                                </div>
                            </div>
                        </a>
                    </div>
                }
                else
                {
                    <!-- Tarjeta inactiva -->
                    <div class="col">
                        <div class="card h-100 card-inactiva"
                             role="button"
                             data-bs-toggle="modal"
                             data-bs-target="#modalInactiva">
                            <div class="card-body d-flex flex-column gap-2 p-4">
                                <div class="d-flex align-items-center gap-3 mb-1">
                                    <span class="d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                                          style="width:44px;height:44px;background-color:#cccccc;">
                                        <i class="bi bi-lock-fill" style="color:#999999;"></i>
                                    </span>
                                    <h5 class="card-title fw-bold mb-0 titulo-inactivo">
                                        @inst.NombreInstitucion
                                    </h5>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(inst.Direccion))
                                {
                                    <p class="card-text small mb-0">
                                        <i class="bi bi-geo-alt-fill me-1"></i>@inst.Direccion
                                    </p>
                                }
                            </div>
                            <div class="card-footer border-0 py-2 px-4"
                                 style="background-color:#e0e0e0;">
                                <span class="small fw-semibold footer-inactivo">
                                    <i class="bi bi-slash-circle me-1"></i>Institución inactiva
                                </span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }

    <!-- Volver al inicio -->
    <div class="text-center mt-5">
        <a asp-controller="Home" asp-action="Index"
           class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i>Volver al inicio
        </a>
    </div>

</div>

<!-- Modal: institución inactiva -->
<div class="modal fade" id="modalInactiva" tabindex="-1" aria-labelledby="modalInactivaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0" style="background-color:#1a2e4a;">
                <h5 class="modal-title text-white fw-semibold" id="modalInactivaLabel">
                    <i class="bi bi-lock-fill me-2"></i>Institución no disponible
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body text-center py-4 px-5">
                <i class="bi bi-lock-fill fs-1 mb-3 d-block" style="color:#cccccc;"></i>
                <p class="mb-0 fs-6">
                    Esta institución se encuentra <strong>inactiva</strong>.<br />
                    Por favor contacte al administrador.
                </p>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-secondary fw-semibold px-4"
                        data-bs-dismiss="modal">
                    Entendido
                </button>
            </div>
        </div>
    </div>
</div>
